# ==========================================
# Arjuna Speaks — Environment Variables
# ==========================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# === GROQ API (REQUIRED for AI Chat) ===
# Get your free API key at: https://console.groq.com/keys
VITE_GROQ_API_KEY=gsk_your_groq_api_key_here

# === USE PROXY (Optional — for corporate networks) ===
# Set to 'true' when deployed on Vercel to route API calls through
# your own domain (bypasses corporate firewalls that block api.groq.com)
# For local dev, keep unset or false (uses direct API call)
# VITE_USE_PROXY=true

# === Google Drive (Optional — for saving reports) ===
# Get OAuth 2.0 Client ID at: https://console.cloud.google.com/apis/credentials
# VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# === Google Drive Folder IDs (Optional) ===
# Create folders in Google Drive and use their IDs for organized storage
# VITE_GOOGLE_DRIVE_UPLOADS_FOLDER_ID=
# VITE_GOOGLE_DRIVE_REPORTS_FOLDER_ID=
